# .env.example

# Database Configuration
DB_PASSWORD=changeme
DB_URL=postgres://agent:changeme@db:5432/jobagent?sslmode=disable

# Telegram Bot Configuration (optional if using html/csv reports)
TELEGRAM_BOT_TOKEN=        # from @BotFather on Telegram
TELEGRAM_CHAT_ID=          # your personal chat ID

# AI Scoring Configuration (optional - leave empty to skip AI scoring)
GEMINI_API_KEY=            # from aistudio.google.com

# Scheduler Configuration
SCAN_INTERVAL_HOURS=6      # how often to run, default 6

# Report Configuration
REPORT_FORMAT=html         # telegram | html | csv | all (default: html)
REPORT_OUTPUT_DIR=./reports  # where to save html/csv reports (default: ./reports)

